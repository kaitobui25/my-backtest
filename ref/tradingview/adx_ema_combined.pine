// ┌──────────────────────────────────────────────────────────────────────┐
// │  ADX + EMA Combined Indicator (Overlay)                            │
// │  Version: 1.0 | Pine Script v6                                     │
// └──────────────────────────────────────────────────────────────────────┘
//
// ── MÔ TẢ ──────────────────────────────────────────────────────────────
//  Gộp ADX (Average Directional Index) và 4 đường EMA vào 1 script
//  overlay trực tiếp trên nến. ADX không vẽ đường (vì khác đơn vị
//  so với giá) mà thể hiện qua:
//    1. bgcolor()  — tô màu nền mỗi bar theo trạng thái trend
//    2. table      — hiển thị giá trị ADX, +DI, -DI ở góc phải trên
//
// ── CÁCH ĐỌC MÀU NỀN ──────────────────────────────────────────────────
//  🟢 Xanh lá  → Trending UP   (ADX ≥ threshold AND +DI > -DI)
//  🔴 Đỏ       → Trending DOWN (ADX ≥ threshold AND -DI > +DI)
//  ⚫ Xám      → Sideway       (ADX < threshold)
//
// ── THÔNG SỐ EMA ───────────────────────────────────────────────────────
//  EMA 1 Length  (mặc định: 20)  — EMA ngắn, đường đỏ
//  EMA 2 Length  (mặc định: 50)  — EMA trung, đường cam
//  EMA 3 Length  (mặc định: 100) — EMA dài, đường aqua
//  EMA 4 Length  (mặc định: 200) — EMA rất dài, đường xanh dương (dày)
//  Show EMAs     (mặc định: ON)  — Bật/tắt hiển thị tất cả EMA
//
// ── THÔNG SỐ ADX ───────────────────────────────────────────────────────
//  DI Length     (mặc định: 14)  — Chu kỳ tính +DI / -DI
//  ADX Smoothing (mặc định: 14)  — Chu kỳ làm mượt ADX
//  ADX Threshold (mặc định: 25)  — Ngưỡng xác định có trend hay không
//     - ADX ≥ threshold → thị trường có trend (xem +DI/-DI để biết hướng)
//     - ADX < threshold → sideway, tránh vào lệnh
//     - Hạ xuống 20 nếu muốn nhạy hơn, tăng lên 30 nếu chỉ bắt trend mạnh
//  Show +DI/-DI  (mặc định: ON)  — Hiện giá trị DI trong bảng
//  Color BG      (mặc định: ON)  — Bật/tắt tô màu nền
//  BG Opacity    (mặc định: 88)  — Độ trong suốt nền (0=đậm, 100=trong)
//
// ── CÁCH SỬ DỤNG ──────────────────────────────────────────────────────
//  1. Chỉ trade khi nền XANH hoặc ĐỎ (có trend), bỏ qua nền xám
//  2. Kết hợp EMA xác nhận hướng:
//     - Nền xanh + giá trên EMA 50/100 → tìm entry LONG
//     - Nền đỏ  + giá dưới EMA 50/100 → tìm entry SHORT
//  3. EMA 200 dùng làm support/resistance động dài hạn
//  4. Bảng góc phải trên cho giá trị số chính xác của ADX, +DI, -DI
//
// ── CÁCH ADD VÀO TRADINGVIEW ───────────────────────────────────────────
//  1. Mở TradingView → Pine Editor (tab dưới chart)
//  2. Paste toàn bộ nội dung file này
//  3. Bấm "Add to chart"
//  4. Chỉnh thông số trong Settings (icon bánh răng)
//
// ════════════════════════════════════════════════════════════════════════

//@version=6
indicator("ADX + EMA", shorttitle="ADX+EMA", overlay=true)

// ══════════════════════════════════════════════
//  INPUTS — EMA
// ══════════════════════════════════════════════
grpEMA    = "── EMA Settings ──"
ema20Len  = input.int(20,  "EMA 1 Length", minval=1, group=grpEMA)
ema50Len  = input.int(50,  "EMA 2 Length", minval=1, group=grpEMA)
ema100Len = input.int(100, "EMA 3 Length", minval=1, group=grpEMA)
ema200Len = input.int(200, "EMA 4 Length", minval=1, group=grpEMA)
showEMA   = input.bool(true, "Show EMAs",  group=grpEMA)

// ══════════════════════════════════════════════
//  INPUTS — ADX
// ══════════════════════════════════════════════
grpADX      = "── ADX Settings ──"
diLen       = input.int(14, "DI Length",     minval=1, group=grpADX)
adxLen      = input.int(14, "ADX Smoothing", minval=1, group=grpADX)
adxThresh   = input.int(25, "ADX Threshold (Trend Signal)", minval=0, maxval=100, group=grpADX)
showBG      = input.bool(true,  "Color Background by ADX State", group=grpADX)
showTable   = input.bool(true,  "Show ADX Info Table",           group=grpADX)
bgAlpha     = input.int(88, "Background Opacity (0=solid,100=transparent)", minval=0, maxval=100, group=grpADX)

// ══════════════════════════════════════════════
//  EMA CALCULATIONS
// ══════════════════════════════════════════════
ema20  = ta.ema(close, ema20Len)
ema50  = ta.ema(close, ema50Len)
ema100 = ta.ema(close, ema100Len)
ema200 = ta.ema(close, ema200Len)

// ══════════════════════════════════════════════
//  ADX / DI CALCULATIONS
// ══════════════════════════════════════════════
dirmov(len) =>
    up      = ta.change(high)
    down    = -ta.change(low)
    plusDM  = na(up)   ? na : (up   > down and up   > 0 ? up   : 0)
    minusDM = na(down) ? na : (down > up   and down > 0 ? down : 0)
    tr      = ta.rma(ta.tr, len)
    plus    = fixnan(100 * ta.rma(plusDM,  len) / tr)
    minus   = fixnan(100 * ta.rma(minusDM, len) / tr)
    [plus, minus]

[diPlus, diMinus] = dirmov(diLen)
diSum  = diPlus + diMinus
adxVal = 100 * ta.rma(math.abs(diPlus - diMinus) / (diSum == 0 ? 1 : diSum), adxLen)

// ══════════════════════════════════════════════
//  ADX STATE LOGIC
//  Trending Up   : ADX > threshold AND +DI > -DI
//  Trending Down : ADX > threshold AND -DI > +DI
//  No Trend      : ADX <= threshold
// ══════════════════════════════════════════════
isTrending  = adxVal >= adxThresh
isBullish   = isTrending and diPlus  > diMinus
isBearish   = isTrending and diMinus > diPlus

bgColor = isBullish ? color.new(color.green,  bgAlpha) :
          isBearish ? color.new(color.red,     bgAlpha) :
                      color.new(color.gray,    bgAlpha + 7)

// ══════════════════════════════════════════════
//  PLOTS — EMA
// ══════════════════════════════════════════════
plot(showEMA ? ema20  : na, "EMA 20",  color=color.new(color.red,    0), linewidth=1)
plot(showEMA ? ema50  : na, "EMA 50",  color=color.new(color.orange, 0), linewidth=1)
plot(showEMA ? ema100 : na, "EMA 100", color=color.new(color.aqua,   0), linewidth=1)
plot(showEMA ? ema200 : na, "EMA 200", color=color.new(color.blue,   0), linewidth=2)

// ══════════════════════════════════════════════
//  BACKGROUND — ADX State
// ══════════════════════════════════════════════
bgcolor(showBG ? bgColor : na, title="ADX Background")

// ══════════════════════════════════════════════
//  TABLE — ADX Info (top-right corner)
// ══════════════════════════════════════════════
if showTable and barstate.islast
    var tbl = table.new(position.top_right, 2, 4,
                        border_width=1,
                        border_color=color.new(color.gray, 60),
                        bgcolor=color.new(color.black, 30))

    // Header
    table.cell(tbl, 0, 0, "Indicator", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20))
    table.cell(tbl, 1, 0, "Value",     text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20))

    // ADX row
    adxColor = isBullish ? color.lime : isBearish ? color.red : color.gray
    table.cell(tbl, 0, 1, "ADX(" + str.tostring(adxLen) + ")", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(adxVal, "#.##"),        text_color=adxColor,    text_size=size.small)

    // +DI row
    table.cell(tbl, 0, 2, "+DI", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(diPlus,  "#.##"),
               text_color=diPlus > diMinus ? color.lime : color.gray, text_size=size.small)

    // -DI row
    table.cell(tbl, 0, 3, "-DI", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(diMinus, "#.##"),
               text_color=diMinus > diPlus ? color.red : color.gray, text_size=size.small)
