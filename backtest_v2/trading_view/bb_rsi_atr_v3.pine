//@version=6
// Thêm max_boxes_count = 500 để lưu giữ 500 khối hộp giao dịch trong quá khứ 
indicator("BB + RSI/ATR Visual Dashboard V3", shorttitle="BB_RSI_ATR_V3", overlay=true, max_boxes_count=500)

// ==========================================
// 1. BOLLINGER BANDS (MẶC ĐỊNH UNCHECK)
// ==========================================
grp_bb     = "Bollinger Bands"
bb_length  = input.int(20,       "Length", minval = 1, group=grp_bb)
bb_src     = input(close,        "Source", group=grp_bb)
bb_mult    = input.float(2.0,    "StdDev", minval = 0.001, maxval = 50, group=grp_bb)

bb_basis = ta.sma(bb_src, bb_length)
bb_dev   = bb_mult * ta.stdev(bb_src, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

// Thêm display=display.none để mặc định Mù/Tắt (Uncheck) khi khởi tạo
plot(bb_basis, "BB Basis", color=#2962FF, display=display.none)
p1 = plot(bb_upper, "BB Upper", color=#F23645, display=display.none)
p2 = plot(bb_lower, "BB Lower", color=#089981, display=display.none)
fill(p1, p2, title = "BB Background", color=color.rgb(33, 150, 243, 95), display=display.none)

// ==========================================
// 2. TÍNH TOÁN RSI & ATR
// ==========================================
grp_rsi = "RSI Settings"
rsi_len = input.int(14, "RSI Length", group=grp_rsi)
rsi_ob  = input.int(70, "Overbought", group=grp_rsi) 
rsi_os  = input.int(30, "Oversold", group=grp_rsi)   
rsi_val = ta.rsi(close, rsi_len)

grp_atr    = "ATR Settings"
atr_len    = input.int(14, title="ATR Length", minval=1, group=grp_atr)
atr_smooth = input.string(title="ATR Smoothing", defval="RMA", options=["RMA", "SMA", "EMA", "WMA"], group=grp_atr)

ma_func(source, length) =>
    switch atr_smooth
        "RMA" => ta.rma(source, length)
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        => ta.wma(source, length)

atr_val = ma_func(ta.tr(true), atr_len)

// Đổi màu nến theo RSI = mặc định false (Uncheck) theo yêu cầu
show_bar_color = input.bool(false, "Màu nến theo RSI Quá mức", group=grp_rsi)
barColorRSI = rsi_val >= rsi_ob ? color.new(#E91E63, 0) : rsi_val <= rsi_os ? color.new(#FFEB3B, 0) : na
barcolor(show_bar_color ? barColorRSI : na, title="RSI Candle Color")


// ==========================================
// 3. TÍNH TOÁN ADX
// ==========================================
grp_adx    = "ADX Settings"
adx_len    = input.int(14, "ADX Length", group=grp_adx)
adx_thresh = input.int(25, "ADX Threshold", group=grp_adx)

[diplus, diminus, adx_val] = ta.dmi(adx_len, adx_len)

// ==========================================
// 4. TOP 3 SYSTEM (VISUAL BOX TP/SL)
// ==========================================
grp_sig = "Top 3 Trading System"
show_signals = input.bool(true, "1. Hiển thị Lệnh Buy / Sell", group=grp_sig)
show_tpsl    = input.bool(true, "2. Hiển thị Box Vùng TP / SL", group=grp_sig)
sl_multi     = input.float(1.5, "Stop Loss (ATR Multiplier)", group=grp_sig)
rr_ratio     = input.float(1.5, "Risk/Reward Ratio (TP Mutiplier)", group=grp_sig)
wait_candles = input.int(2, "Số nến chờ (Wait Candles)", group=grp_sig)

// Giao diện màu Box
tpCss = input.color(color.new(#5b9cf6, 80), 'Màu Box TP Area', inline='tpsl', group=grp_sig)
slCss = input.color(color.new(color.gray, 80), 'Màu Box SL Area', inline='tpsl', group=grp_sig) 

atr_200 = ta.atr(200)

var float ep = na 
var float sl = na  
var float tp = na  
var int   dir = 0
var box tp_area = na
var box sl_area = na
var int bars_since_exit = 9999

// --- Cập nhật tiến trình của lệnh (Update TP/SL) ---
hit_exit = false
if dir != 0
    // Cơi nới độ dài hộp trượt theo nến hiện tại
    if show_tpsl
        box.set_right(tp_area, bar_index)
        box.set_right(sl_area, bar_index)
        
    // Kiểm tra đã hit TP/SL chưa
    if dir == 1
        if high >= tp or low <= sl
            dir := 0 
            hit_exit := true
    else if dir == -1
        if low <= tp or high >= sl
            dir := 0 
            hit_exit := true

// Cập nhật biến đếm khoảng cách thời gian giữa các lệnh
if dir == 0 and not hit_exit
    bars_since_exit += 1
if hit_exit
    bars_since_exit := 0

// --- Điều kiện vào lệnh ---
adx_ok = adx_val >= adx_thresh
can_trade = (dir == 0) and (bars_since_exit >= wait_candles) and not na(atr_200)

base_long  = (close[1] < bb_lower[1]) and (close > bb_lower) and (rsi_val < 45) and adx_ok
base_short = (close[1] > bb_upper[1]) and (close < bb_upper) and (rsi_val > 55) and adx_ok

longCond  = base_long  and can_trade
shortCond = base_short and can_trade

if longCond
    ep := close
    sl := close - (sl_multi * atr_200)
    tp := close + ((sl_multi * rr_ratio) * atr_200)
    dir := 1

    if show_tpsl
        tp_area := box.new(bar_index, tp, bar_index, ep, na, bgcolor = tpCss)
        sl_area := box.new(bar_index, ep, bar_index, sl, na, bgcolor = slCss)

else if shortCond
    ep := close
    sl := close + (sl_multi * atr_200)
    tp := close - ((sl_multi * rr_ratio) * atr_200)
    dir := -1

    if show_tpsl
        tp_area := box.new(bar_index, ep, bar_index, tp, na, bgcolor = tpCss)
        sl_area := box.new(bar_index, sl, bar_index, ep, na, bgcolor = slCss)

// Vẽ tín hiệu Mua/Bán (Chỉ in khi MỞ LỆNH thành công)
plotshape(show_signals and longCond,  "Buy Signal",  shape.triangleup,   location.belowbar, color.new(color.green,0), text="BUY",  textcolor=color.white, size=size.small)
plotshape(show_signals and shortCond, "Sell Signal", shape.triangledown, location.abovebar, color.new(color.red,0),   text="SELL", textcolor=color.white, size=size.small)

// ==========================================
// 5. BẢNG THÔNG SỐ GÓC MÀN HÌNH (DASHBOARD)
// ==========================================
var table panel = table.new(position.bottom_right, 2, 3, border_width=1, border_color=color.rgb(66, 66, 66))

if barstate.islast
    rsi_bg_color = rsi_val >= rsi_ob ? color.new(color.red, 40) : rsi_val <= rsi_os ? color.new(color.green, 40) : color.new(color.gray, 70)
    adx_bg_color = adx_val >= adx_thresh ? color.new(color.green, 40) : color.new(color.gray, 70)
    
    table.cell(panel, 0, 0, "ADX (14)", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 0, str.tostring(adx_val, "#.##"), text_color=color.white, bgcolor=adx_bg_color, text_size=size.small)
    
    table.cell(panel, 0, 1, "RSI (14)", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 1, str.tostring(rsi_val, "#.##"), text_color=color.white, bgcolor=rsi_bg_color, text_size=size.small)
    
    table.cell(panel, 0, 2, "ATR (14)", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 2, str.tostring(atr_val, "#.####"), text_color=color.white, bgcolor=color.new(#1565C0, 30), text_size=size.small)
